{
  "info": {
    "name": "Inspire Auth — JWT双Token认证",
    "description": "基于文档《JWT双Token认证体系》的接口测试集合\n\n环境变量：\n- baseUrl: http://localhost:8080/api\n- adminToken: （登录后自动填充）\n- refreshToken: （登录后自动填充）\n- adminUserId: 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "流程一：用户登录",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.code === 200 && jsonData.data) {",
              "    var d = jsonData.data;",
              "    pm.collectionVariables.set('accessToken', d.accessToken);",
              "    pm.collectionVariables.set('refreshToken', d.refreshToken);",
              "    pm.collectionVariables.set('userId', String(d.userId));",
              "    pm.environment.set('adminToken', d.accessToken);",
              "    console.log('AccessToken:', d.accessToken);",
              "    console.log('RefreshToken:', d.refreshToken);",
              "    console.log('ExpiresIn:', d.expiresIn, '秒');",
              "    pm.test('登录成功，返回双Token', () => {",
              "        pm.expect(d.accessToken).to.not.be.empty;",
              "        pm.expect(d.refreshToken).to.not.be.empty;",
              "        pm.expect(d.expiresIn).to.eq(900);",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"123456\",\n  \"deviceId\": \"postman-test-device\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "流程二：业务请求（验证Token鉴权）",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/userinfo",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "userinfo"]
        }
      }
    },
    {
      "name": "流程三：刷新AccessToken",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.code === 200 && jsonData.data) {",
              "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
              "    pm.test('刷新成功，获取新AccessToken', () => {",
              "        pm.expect(jsonData.data.accessToken).to.not.be.empty;",
              "        pm.expect(jsonData.data.refreshToken).to.eq(pm.collectionVariables.get('refreshToken'));",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Refresh-Token", "value": "{{refreshToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh"]
        }
      }
    },
    {
      "name": "流程四：用户登出",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.test('登出成功', () => { pm.expect(jsonData.code).to.eq(200); });",
              "pm.collectionVariables.set('accessToken', '');",
              "pm.collectionVariables.set('refreshToken', '');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "logout"]
        }
      }
    },
    {
      "name": "流程五：强制下线（管理员踢人）",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/admin/kick/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "admin", "kick", "{{userId}}"]
        }
      }
    },
    {
      "name": "Token过期401测试（无Token请求）",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.test('无Token返回401001', () => {",
              "    pm.expect(jsonData.code).to.eq(401001);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/auth/userinfo",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "userinfo"]
        }
      }
    }
  ]
}
